+    auto    ir = &data_->ir;
+
+    msg("------------------------------\n");
+    if (data_->filever >= 53)
+    {
+        if (!tpr_.do_int(reinterpret_cast<int*>(&ir->pbc))) return TPR_FAILED;
+        msg("pbcType= %d\n", static_cast<int>(data_->ir.pbc));
