+static void print_vec(const char *name, float *arr, int len = DIM*DIM)
+{
+#ifdef _DEBUG
+    msg(name);
+    for (int i = 0; i < len; i++) fprintf(stderr, "%f ", arr[i]);
+    printf("\n");
+#endif // _DEBUG
